# ===== RabbitMQ =====
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ===== Banco (vazio = H2 file local; no docker-compose usa PostgreSQL) =====
# DB_URL=jdbc:postgresql://localhost:5432/gateway_db
# DB_USER=promo
# DB_PASS=promo
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ===== Regras / chaves =====
HOT_DEAL_THRESHOLD=5
# Diretorio das chaves RSA (no docker: /keys; local: ../../keys relativo a cada servico)
KEYS_DIR=

# ===== API de e-mail (MS Notificacao) =====
# provider=resend usa a API real; sem RESEND_API_KEY cai para mock (apenas loga)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Promocoes <onboarding@resend.dev>

# ===== Frontend (Nuxt) =====
# URL do Gateway usada pelo navegador (REST + SSE)
NUXT_PUBLIC_GATEWAY_URL=http://localhost:8080
